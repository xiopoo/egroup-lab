{
  "version": 2,
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/diag", "dest": "/public/diag.html" },
    { "src": "/intro", "dest": "/public/intro.html" },
    { "src": "/(.*)\\.html", "dest": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/public/(.*)\\.(jpg|jpeg|png|svg|ico|webp|gif|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/public/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
