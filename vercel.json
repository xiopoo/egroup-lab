{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/about", "destination": "/public/about.html" },
    { "source": "/services", "destination": "/public/services.html" },
    { "source": "/cases", "destination": "/public/cases.html" },
    { "source": "/diag", "destination": "/public/diag.html" },
    { "source": "/intro", "destination": "/public/intro.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "notFound": {
    "path": "/public/404.html"
  },
  "headers": [
    {
      "source": "/(.*)\\.(jpg|jpeg|png|svg|ico|webp|gif|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
